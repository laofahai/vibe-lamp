(kicad_pcb
  (version 20240108)
  (generator "codex")
  (generator_version "1.0")

  (general
    (thickness 1.6)
    (legacy_teardrops no)
  )

  (paper "A4")

  (layers
    (0 "F.Cu" signal)
    (31 "B.Cu" signal)
    (32 "B.Adhes" user "B.Adhesive")
    (33 "F.Adhes" user "F.Adhesive")
    (34 "B.Paste" user)
    (35 "F.Paste" user)
    (36 "B.SilkS" user "B.Silkscreen")
    (37 "F.SilkS" user "F.Silkscreen")
    (38 "B.Mask" user)
    (39 "F.Mask" user)
    (44 "Edge.Cuts" user)
    (45 "Margin" user)
    (46 "B.CrtYd" user "B.Courtyard")
    (47 "F.CrtYd" user "F.Courtyard")
    (48 "B.Fab" user)
    (49 "F.Fab" user)
    (50 "User.1" user "Mechanical")
    (51 "User.2" user "AssemblyNotes")
  )

  (setup
    (pad_to_mask_clearance 0)
    (allow_soldermask_bridges_in_footprints no)
    (tenting front back)
    (pcbplotparams
      (layerselection 0x00010fc_ffffffff)
      (plot_on_all_layers_selection 0x0000000_00000000)
      (disableapertmacros no)
      (usegerberextensions no)
      (usegerberattributes yes)
      (usegerberadvancedattributes yes)
      (creategerberjobfile yes)
      (dashed_line_dash_ratio 12.000000)
      (dashed_line_gap_ratio 3.000000)
      (svgprecision 4)
      (plotframeref no)
      (viasonmask no)
      (mode 1)
      (useauxorigin no)
      (hpglpennumber 1)
      (hpglpenspeed 20)
      (hpglpendiameter 15.000000)
      (pdf_front_fp_property_popups yes)
      (pdf_back_fp_property_popups yes)
      (pdf_metadata yes)
      (pdf_single_document no)
      (dxfpolygonmode yes)
      (dxfimperialunits yes)
      (dxfusepcbnewfont yes)
      (psnegative no)
      (psa4output no)
      (plot_black_and_white no)
      (plotinvisibletext no)
      (sketchpadsonfab no)
      (plotpadnumbers no)
      (hidednponfab no)
      (sketchdnponfab yes)
      (crossoutdnponfab yes)
      (plotfptext yes)
      (subtractmaskfromsilk no)
      (outputformat 1)
      (mirror no)
      (drillshape 1)
      (scaleselection 1)
      (outputdirectory "gerbers/")
    )
  )

  (net 0 "")
  (net 1 "+5V")
  (net 2 "GND")
  (net 3 "+3V3")
  (net 4 "USB_DP")
  (net 5 "USB_DN")
  (net 6 "LED_DIN")
  (net 7 "LED_D1_D2")
  (net 8 "LED_D2_D3")
  (net 9 "LED_D3_D4")
  (net 10 "RESET_BTN")
  (net 11 "EN")

  (gr_rect
    (start 100 100)
    (end 138 116)
    (stroke (width 0.1) (type solid))
    (fill none)
    (layer "Edge.Cuts")
  )

  (gr_line (start 101.5 101.2) (end 136.5 101.2)
    (stroke (width 0.12) (type dash)) (layer "User.1"))
  (gr_text "LED / diffuser edge" (at 119 102.2 0)
    (layer "User.1")
    (effects (font (size 1.0 1.0) (thickness 0.12)) (justify bottom))
  )
  (gr_rect (start 108 105) (end 130 112)
    (stroke (width 0.12) (type dash)) (fill none) (layer "User.1"))
  (gr_text "magnet area in enclosure\nkeep metal away from antenna" (at 119 108.5 0)
    (layer "User.1")
    (effects (font (size 0.9 0.9) (thickness 0.1)) (justify center))
  )
  (gr_rect (start 100.6 100.5) (end 137.4 104.2)
    (stroke (width 0.12) (type dash)) (fill none) (layer "User.2"))
  (gr_text "ESP32-C3 antenna keepout: no copper, no magnet, no screw" (at 119 100.85 0)
    (layer "User.2")
    (effects (font (size 0.7 0.7) (thickness 0.08)) (justify top))
  )
  (gr_text "VIBE LAMP EDGE V1  38x16mm  FR4 2L 1.6mm  6/6mil  0.3mm drill" (at 119 114.8 0)
    (layer "F.SilkS")
    (effects (font (size 0.75 0.75) (thickness 0.1)) (justify center))
  )
  (gr_text "USB-C bottom edge" (at 119 115.8 0)
    (layer "User.1")
    (effects (font (size 0.8 0.8) (thickness 0.1)) (justify center bottom))
  )

