    (pad "A6" smd roundrect (at -0.45 -1.35 180) (size 0.28 1.2) (layers "F.Cu" "F.Paste" "F.Mask") (roundrect_rratio 0.25) (net 4 "USB_DP"))
    (pad "A7" smd roundrect (at 0.45 -1.35 180) (size 0.28 1.2) (layers "F.Cu" "F.Paste" "F.Mask") (roundrect_rratio 0.25) (net 5 "USB_DN"))
    (pad "S1" thru_hole oval (at -4.1 0 180) (size 1.4 2.4) (drill oval 0.6 1.2) (layers "*.Cu" "*.Mask") (net 2 "GND"))
    (pad "S2" thru_hole oval (at 4.1 0 180) (size 1.4 2.4) (drill oval 0.6 1.2) (layers "*.Cu" "*.Mask") (net 2 "GND"))
  )

